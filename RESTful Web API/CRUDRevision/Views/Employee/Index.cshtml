@using System.Data

<h2>Employee List</h2>

<a class="btn btn-primary mb-3" asp-action="AddEdit">Add Employee</a>
<a class="btn btn-primary mb-3" asp-action="ExportToExcel">Export to Excel</a>
<!-- Search Filter Form -->
<form method="get" asp-action="Index" class="mb-4">
    <div class="row g-2">
        <div class="col-md-2">
            <input type="text" name="EmpName" class="form-control" placeholder="Employee Name" value="@ViewBag.EmpName" />
        </div>
        <div class="col-md-2">
            <input type="number" step="0.01" name="MinSalary" class="form-control" placeholder="Min Salary" value="@ViewBag.MinSalary" />
        </div>
        <div class="col-md-2">
            <input type="number" step="0.01" name="MaxSalary" class="form-control" placeholder="Max Salary" value="@ViewBag.MaxSalary" />
        </div>
        <div class="col-md-2">
            <select name="DeptID" class="form-control">
                <option value="0">-- Department --</option>
                @if (ViewBag.DeptList != null)
                {
                    foreach (var dept in ViewBag.DeptList)
                    {
                        var selected = ViewBag.SelectedDeptID == dept.DeptID;
                        <option value="@dept.DeptID" selected="@selected">
                            @dept.DepartmentName
                        </option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <input type="date" name="JoiningDateFrom" class="form-control" placeholder="Joining Date From" value="@(ViewBag.JoiningDateFrom != null ? ((DateTime)ViewBag.JoiningDateFrom).ToString("yyyy-MM-dd") : "")" />
        </div>
        <div class="col-md-2">
            <input type="date" name="JoiningDateTo" class="form-control" placeholder="Joining Date To" value="@(ViewBag.JoiningDateTo != null ? ((DateTime)ViewBag.JoiningDateTo).ToString("yyyy-MM-dd") : "")" />
        </div>
        <div class="col-md-2">
            <input type="text" name="City" class="form-control" placeholder="City" value="@ViewBag.City" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </div>
</form>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Salary</th>
            <th>Joining Date</th>
            <th>City</th>
            <th>Department</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (DataRow row in Model.Rows)
        {
            <tr>
                <td>@row["EmpName"]</td>
                <td>@row["Salary"]</td>
                <td>@Convert.ToDateTime(row["JoiningDate"]).ToShortDateString()</td>
                <td>@row["City"]</td>
                <td>@row["DepartmentName"]</td>

                <td class="text-center">
                    <a class="btn btn-success btn-sm"
                       asp-route-EmpID="@row["EmpID"]"
                       asp-action="AddEdit">Edit</a>

                    <a class="btn btn-danger btn-sm"
                       asp-route-EmpID="@row["EmpID"]"
                       asp-action="Delete"
                       onclick="return confirm('Delete this employee?');">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
